# 통합 테스트용 환경변수 (운영 DB와 분리된 test DB)
# 이 파일을 복사해서 backend/config/.env.test 로 사용
# .env.test 는 .gitignore 에 의해 커밋되지 않음

NODE_ENV=test
PORT=3001

# Test DB (운영 DB의 dump/restore 된 별도 프로세스)
TEST_DB_HOST=localhost
TEST_DB_PORT=5433
TEST_DB_NAME=my_blog_test
TEST_DB_USER=postgres
TEST_DB_PASSWORD=

SESSION_SECRET=test-secret-key
FRONTEND_URL=http://localhost:4322
