{
  "name": "my-node-server",
  "version": "1.0.0",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon --config ./config/nodemon.json app.js",
    "test": "vitest run --config ./config/vitest.config.js",
    "test:watch": "vitest --config ./config/vitest.config.js",
    "test:integration": "vitest run --config ./config/vitest.integration.config.js",
    "lint": "eslint . --config ./config/eslint.config.js",
    "lint:fix": "eslint . --fix --config ./config/eslint.config.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "",
  "dependencies": {
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "5.2.1",
    "express-session": "1.18.1",
    "katex": "^0.16.33",
    "marked": "15.0.6",
    "pg": "8.13.1",
    "sanitize-html": "2.14.0"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "9.17.0",
    "globals": "15.14.0",
    "nodemon": "3.1.9",
    "prettier": "3.4.2",
    "vitest": "^2.1.0"
  }
}
